{
  "version": "2026-04-24",
  "task_stages": [
    {
      "id": "explore",
      "label": "exploration",
      "goal": "find viable directions and widen variation"
    },
    {
      "id": "converge",
      "label": "convergence",
      "goal": "keep the right direction and fix the key gaps"
    },
    {
      "id": "finalize",
      "label": "finalization",
      "goal": "make only the last-mile delivery adjustments"
    }
  ],
  "revision_modes": [
    {
      "id": "new_direction",
      "label": "new direction",
      "goal": "allow a fresh concept direction or a new subject branch",
      "default_change_axis": "direction"
    },
    {
      "id": "structure_refine",
      "label": "structure refine",
      "goal": "keep the validated direction and change structure, silhouette, or garment logic",
      "default_change_axis": "structure"
    },
    {
      "id": "colorway_only",
      "label": "colorway only",
      "goal": "change only palette assignment on the same approved design",
      "default_change_axis": "palette"
    },
    {
      "id": "finish_only",
      "label": "finish only",
      "goal": "change only cleanliness, polish, or delivery finish",
      "default_change_axis": "finish"
    },
    {
      "id": "local_edit",
      "label": "local edit",
      "goal": "modify only a bounded selected region or the existing image canvas",
      "default_change_axis": "local"
    }
  ],
  "lock_states": [
    {
      "id": "unlocked",
      "goal": "the design is still open and can change direction"
    },
    {
      "id": "soft_locked",
      "goal": "major elements should stay close, but no strong base anchor is confirmed yet"
    },
    {
      "id": "hard_locked",
      "goal": "the current base design is approved enough to support strict colorway-only or finish-only changes"
    }
  ],
  "deliverable_types": [
    "selectable_grid",
    "single_direction_frame",
    "design_sheet",
    "proposal_visual",
    "final_key_visual",
    "video_clip",
    "style_system_asset"
  ],
